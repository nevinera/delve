{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zone",
  "title": "Zone",
  "description": "A dungeon zone: map, walls, and the units currently present.",
  "type": "object",
  "required": ["name", "mapUrl", "dimensions", "walls", "units"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name for this zone."
    },
    "mapUrl": {
      "type": "string",
      "description": "URL of the dungeon map image."
    },
    "dimensions": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "description": "Map dimensions in feet.",
      "properties": {
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "startingLocations": {
      "type": "array",
      "description": "Candidate spawn points for player tokens, in map coordinates.",
      "items": {
        "type": "object",
        "required": ["x", "y", "facing"],
        "additionalProperties": false,
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "facing": {
            "type": "number",
            "description": "Initial facing direction in radians, using the same convention as unit facingAngle."
          }
        }
      }
    },
    "walls": {
      "type": "array",
      "description": "Array of wall paths. Each path is a connected sequence of at least two points rendered as a single mitered wall slab.",
      "items": {
        "type": "array",
        "minItems": 2,
        "description": "An ordered sequence of points defining a connected wall path.",
        "items": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        }
      }
    },
    "units": {
      "type": "array",
      "description": "Units currently present in the zone.",
      "items": { "$ref": "unit.json" }
    }
  }
}
