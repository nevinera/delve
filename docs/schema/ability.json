{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ability",
  "title": "Ability",
  "description": "A single active or passive ability belonging to a character class.",
  "type": "object",
  "required": ["name", "effects"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name of the ability."
    },
    "passive": {
      "type": "boolean",
      "default": false,
      "description": "True for passive abilities (always active, not player-triggered)."
    },
    "cost": {
      "type": "number",
      "default": 0,
      "description": "Resource cost to activate. Negative values generate resource instead of spending it."
    },
    "range": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Maximum range in feet to a valid target. Omit for self-only or unlimited-range abilities."
    },
    "graphic": {
      "type": "object",
      "required": ["path", "duration", "type"],
      "additionalProperties": false,
      "description": "Visual effect played when this ability fires.",
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path to the image or animation file."
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Display duration in seconds."
        },
        "type": {
          "type": "string",
          "description": "Effect presentation style (e.g. 'impact', 'beam', 'splash')."
        }
      }
    },
    "sound": {
      "type": "object",
      "required": ["path", "duration", "when"],
      "additionalProperties": false,
      "description": "Audio effect played when this ability fires.",
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path to the audio file."
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Clip duration in seconds."
        },
        "when": {
          "type": "string",
          "description": "Playback trigger (e.g. 'on-cast', 'on-impact')."
        }
      }
    },
    "graphic_from": {
      "type": "object",
      "required": ["type", "duration"],
      "additionalProperties": false,
      "description": "Procedurally generated visual effect (alternative to 'graphic').",
      "properties": {
        "type": {
          "type": "string",
          "description": "Effect style to generate (e.g. 'beam', 'splash', 'pulse')."
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Display duration in seconds."
        },
        "color": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{6}$",
          "description": "Effect color as a 6-digit hex string (no leading #)."
        },
        "transparency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity of the effect, from 0 (invisible) to 1 (fully opaque)."
        }
      }
    },
    "sound_from": {
      "type": "object",
      "required": ["type", "duration"],
      "additionalProperties": false,
      "description": "Procedurally generated audio effect (alternative to 'sound').",
      "properties": {
        "type": {
          "type": "string",
          "description": "Sound style to generate (e.g. 'pew', 'boom', 'chime')."
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Clip duration in seconds."
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Playback volume, from 0 (silent) to 1 (full)."
        }
      }
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered list of effects this ability applies on use.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/harmEffect" },
          { "$ref": "#/$defs/healEffect" },
          { "$ref": "#/$defs/debuffEffect" }
        ]
      }
    }
  },
  "$defs": {
    "harmEffect": {
      "type": "object",
      "required": ["type", "base"],
      "additionalProperties": false,
      "description": "Deals damage to the target.",
      "properties": {
        "type": { "const": "harm" },
        "base": {
          "type": "number",
          "minimum": 0,
          "description": "Base damage before stat scaling."
        },
        "tags": {
          "type": "array",
          "description": "Damage-type tags applied to this hit (e.g. 'dark', 'magic', 'fire').",
          "items": { "type": "string" }
        }
      }
    },
    "healEffect": {
      "type": "object",
      "required": ["type", "base"],
      "additionalProperties": false,
      "description": "Restores HP to a target.",
      "properties": {
        "type": { "const": "heal" },
        "base": {
          "type": "number",
          "minimum": 0,
          "description": "Base heal amount before stat scaling."
        },
        "target": {
          "type": "string",
          "description": "Target selector override (e.g. 'most-damaged-ally'). Omit to use the default heal target."
        }
      }
    },
    "debuffEffect": {
      "type": "object",
      "required": ["type", "name", "effect", "base"],
      "additionalProperties": false,
      "description": "Applies a named debuff to the target.",
      "properties": {
        "type": { "const": "debuff" },
        "name": {
          "type": "string",
          "description": "Identifier for the debuff stack (e.g. 'Warbound'). Stacks with the same name are grouped."
        },
        "effect": {
          "type": "string",
          "description": "The mechanical effect applied (e.g. 'slow', 'weaken')."
        },
        "base": {
          "type": "string",
          "pattern": "^0?\\.[0-9]+$|^[1-9][0-9]*$",
          "description": "Magnitude as a decimal string. Values < 1 are treated as a fraction (e.g. '0.10' = 10% slow)."
        }
      }
    }
  }
}
