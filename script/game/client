#!/usr/bin/env ruby
# frozen_string_literal: true

# Developer WebSocket client for a game server slot. Looks up a character and
# zone in the Rails database, calls JoinZone to obtain a slot on the game
# server, then connects via WebSocket.
#
# Usage:
#   script/game/client --character <id|name> --zone <id|identifier> [options]
#
# Options:
#   -C, --character <id|name>     Character ID or name (required)
#   -Z, --zone <id|identifier>    Zone ID or identifier (required; picks latest version if identifier)
#   -i, --instance <uuid>         Target a specific game server instance (optional)
#   -v, --verbose                 Increase verbosity; use twice (-vv) for all deltas
#
# Environment variables:
#   GAME_SERVER_URL          - base URL (default: http://localhost:8090)
#   GAME_SERVER_AUTH_TOKENS  - comma-separated Bearer tokens for the game API

require "json"
require "net/http"
require "optparse"
require "socket"
require "uri"
require "websocket/driver"
require_relative "../../config/environment"

# ---------------------------------------------------------------------------
# Logger
# ---------------------------------------------------------------------------

class Log
  DARK_GREY = "\e[90m"
  RESET = "\e[0m"

  def initialize(verbose: 0)
    @verbose = verbose
    @color = $stderr.tty?
  end

  def info(msg) = Kernel.warn(msg)
  def warn(msg) = Kernel.warn("WARN: #{msg}")

  def verbose(msg)
    dim(msg) if @verbose >= 1
  end

  def debug(msg)
    dim(msg) if @verbose >= 2
  end

  private

  def dim(msg)
    Kernel.warn(@color ? "#{DARK_GREY}#{msg}#{RESET}" : msg)
  end
end

# ---------------------------------------------------------------------------
# Options
# ---------------------------------------------------------------------------

options = {verbose: 0}

OptionParser.new do |opts|
  opts.banner = "Usage: script/game/client --character <id|name> --zone <id|identifier> [options]"
  opts.on("-C", "--character ID_OR_NAME", "Character ID or name") { |v| options[:character] = v }
  opts.on("-Z", "--zone ID_OR_IDENTIFIER", "Zone ID or identifier") { |v| options[:zone] = v }
  opts.on("-i", "--instance UUID", "Target a specific game server instance") { |v| options[:instance_identifier] = v }
  opts.on("-v", "--verbose", "Increase verbosity (-vv logs all deltas)") { options[:verbose] += 1 }
end.parse!

abort "Error: --character is required" unless options[:character]
abort "Error: --zone is required" unless options[:zone]

log = Log.new(verbose: options[:verbose])

# ---------------------------------------------------------------------------
# Look up character and zone
# ---------------------------------------------------------------------------

character_key = options[:character]
character = if /\A\d+\z/.match?(character_key)
  Character.find_by(id: character_key.to_i)
else
  Character.find_by(name: character_key)
end
abort "Character not found: #{character_key}" unless character

zone_key = options[:zone]
zone = if /\A\d+\z/.match?(zone_key)
  Zone.find_by(id: zone_key.to_i)
else
  Zone.where(identifier: zone_key).order(created_at: :desc).first
end
abort "Zone not found: #{zone_key}" unless zone

# ---------------------------------------------------------------------------
# Join via JoinZone
# ---------------------------------------------------------------------------

log.info "--> Joining zone #{zone.identifier} (#{zone.version}) as #{character.name}..."

join_opts = {character: character, zone: zone}
join_opts[:instance_identifier] = options[:instance_identifier] if options[:instance_identifier]

result = JoinZone.call(**join_opts)

instance_id = result.instance_identifier
slot_id = result.slot_id
token = result.token

log.info "    Instance: #{instance_id}"
log.info "    Slot:     #{slot_id}"

# ---------------------------------------------------------------------------
# WebSocket setup
# ---------------------------------------------------------------------------

server_url = ENV.fetch("GAME_SERVER_URL", "http://localhost:8090")
uri = URI.parse(server_url)
ws_scheme = (uri.scheme == "https") ? "wss" : "ws"
ws_path = "/instances/#{instance_id}/slots/#{slot_id}/connect?token=#{token}"
ws_url = "#{ws_scheme}://#{uri.host}:#{uri.port}#{ws_path}"

log.info "--> Connecting to #{ws_scheme}://#{uri.host}:#{uri.port}#{ws_path.sub(/token=\S+/, "token=<redacted>")}..."

tcp = TCPSocket.new(uri.host, uri.port)
tcp.define_singleton_method(:url) { ws_url }
driver = WebSocket::Driver.client(tcp)

# ---------------------------------------------------------------------------
# State
# ---------------------------------------------------------------------------

units = {}
checksum = nil
open = false
done = false

driver.on(:open) do
  open = true
  log.info "    Connected."
end

driver.on(:message) do |event|
  msg = begin
    JSON.parse(event.data)
  rescue
    nil
  end
  unless msg
    log.warn "non-JSON message received"
    next
  end

  case [msg["direction"], msg["type"]]

  when ["down", "instance-state"]
    units = msg.fetch("units", {})
    checksum = msg["checksum"]
    local = GameApi::Checksum.compute_checksum(units)
    if local == checksum
      log.info "[state] Full state: #{units.size} units. Checksum OK."
    else
      log.warn "checksum mismatch after full state — server=#{checksum} local=#{local}"
    end

  when ["down", "delta"]
    (msg["unit_updates"] || {}).each do |id, patch|
      units[id] ? units[id].merge!(patch) : units[id] = patch
    end
    (msg["unit_removals"] || []).each { |id| units.delete(id) }
    (msg["effect_adds"] || []).each do |add|
      next unless (unit = units[add["unit_id"]])
      effects = unit["active_status_effects"] ||= []
      effects.reject! { |e| e["status_identifier"] == add["status_identifier"] }
      effects << {"status_identifier" => add["status_identifier"], "expires_at" => add["expires_at"]}
    end
    (msg["effect_removes"] || []).each do |rem|
      next unless (unit = units[rem["unit_id"]])
      (unit["active_status_effects"] || []).reject! { |e| e["status_identifier"] == rem["status_identifier"] }
    end

    checksum = msg["checksum"]
    local = GameApi::Checksum.compute_checksum(units)
    if local != checksum
      log.warn "checksum mismatch after delta — server=#{checksum} local=#{local}"
      log.warn "Sending full-state request."
      driver.text(JSON.generate({direction: "up", type: "full-state-request"}))
    end

    empty = (msg["unit_updates"] || {}).empty? &&
      (msg["unit_removals"] || []).empty? &&
      (msg["effect_adds"] || []).empty? &&
      (msg["effect_removes"] || []).empty?

    if empty
      log.debug "[delta] (empty) #{event.data}"
    else
      log.verbose "[delta] #{event.data}"
    end

  else
    log.info "[msg] #{event.data}"
  end
end

driver.on(:close) do |event|
  log.info "    Disconnected (#{event.code}): #{event.reason}"
  done = true
end

driver.on(:error) do |event|
  log.info "WebSocket error: #{event.message}"
end

driver.start

# ---------------------------------------------------------------------------
# I/O loop
# ---------------------------------------------------------------------------

HEARTBEAT_INTERVAL = 0.3
last_heartbeat_at = Time.now - HEARTBEAT_INTERVAL

trap("INT") do
  log.info "\n--> Interrupted, closing..."
  done = true
end

loop do
  break if done

  ready = IO.select([tcp], nil, nil, 0.05)
  if ready
    begin
      data = tcp.read_nonblock(65_536)
      driver.parse(data)
    rescue EOFError, Errno::ECONNRESET
      log.info "Connection lost."
      break
    rescue IO::WaitReadable
      # nothing to read right now
    end
  end

  next unless open
  break if done

  if Time.now - last_heartbeat_at >= HEARTBEAT_INTERVAL
    driver.text(JSON.generate({direction: "up", type: "heartbeat"}))
    last_heartbeat_at = Time.now
  end
end

tcp.close unless tcp.closed?
log.info "--> Done."
