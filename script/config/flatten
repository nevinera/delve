#!/usr/bin/env ruby
# frozen_string_literal: true

# Resolves $ref references in a zone JSON file, producing a single self-contained
# "full" JSON file alongside the input.
#
# Usage:
#   script/config/flatten <zone.json>
#
# Output is written to <zone>.full.json in the same directory.
# $ref values are treated as paths relative to the file containing the reference.
# Resolution is recursive, so referenced files may themselves contain $ref values.

require "json"
require "pathname"

def resolve_ref(ref_value, base_dir, output_dir)
  ref_path = (base_dir / ref_value).cleanpath
  abort "#{ref_path}: file not found (referenced from #{base_dir})" unless ref_path.exist?
  resolve(JSON.parse(File.read(ref_path)), ref_path.dirname, output_dir)
end

def rebase_path(value, base_dir, output_dir)
  return value unless value.start_with?("./", "../")

  (base_dir / value).cleanpath.relative_path_from(output_dir).to_s
end

def resolve(value, base_dir, output_dir)
  case value
  when Hash
    return resolve_ref(value["$ref"], base_dir, output_dir) if value.key?("$ref")

    value.transform_values { |v| resolve(v, base_dir, output_dir) }
  when Array
    value.map { |v| resolve(v, base_dir, output_dir) }
  when String
    rebase_path(value, base_dir, output_dir)
  else
    value
  end
end

abort "Usage: script/config/flatten <zone.json>" unless ARGV.size == 1

input_path = Pathname.new(ARGV[0]).expand_path
abort "File not found: #{input_path}" unless input_path.exist?

output_path = input_path.sub_ext(".full.json")
resolved = resolve(JSON.parse(File.read(input_path)), input_path.dirname, output_path.dirname)

File.write(output_path, JSON.pretty_generate(resolved) + "\n")
warn "Written to #{output_path}"
