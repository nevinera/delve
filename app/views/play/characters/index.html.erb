<h1>Characters</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Class</th>
      <th>Last Played</th>
    </tr>
  </thead>
  <tbody>
    <% @characters.each do |character| %>
      <tr>
        <td><%= link_to character.name, play_character_path(character) %></td>
        <td><%= "#{character.character_class.full_identifier} #{character.character_class.version}" %></td>
        <td><%= character.last_played_at&.strftime("%Y-%m-%d") || "Never" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "New character", new_play_character_path %>
