<h1>Register a Class</h1>

<%= form_with model: @character_class, url: build_character_classes_path do |f| %>
  <% if @character_class.errors.any? %>
    <ul>
      <% @character_class.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :handle_id, "Handle" %>
    <%= f.select :handle_id, @handles.map { |h| [h.identifier, h.id] }, {prompt: "Select a handle"} %>
  </div>

  <div>
    <%= f.label :identifier, "Identifier (e.g. puncher)" %>
    <%= f.text_field :identifier %>
  </div>

  <div>
    <%= f.label :location, "Definition URL" %>
    <%= f.text_field :location %>
  </div>

  <%= f.submit "Register" %>
<% end %>

<%= link_to "Cancel", build_character_classes_path %>
