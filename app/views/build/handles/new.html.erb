<h1>New Handle</h1>

<%= form_with model: @handle, url: build_handles_path do |f| %>
  <% if @handle.errors.any? %>
    <ul>
      <% @handle.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :identifier %>
    <%= f.text_field :identifier %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <%= f.submit "Create" %>
<% end %>

<%= link_to "Cancel", build_handles_path %>
