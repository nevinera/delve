<h1><%= @zone.name %></h1>

<p><strong>Identifier:</strong> <%= @zone.identifier %></p>
<p><strong>Version:</strong> <%= @zone.version %></p>
<p><strong>Handle:</strong> <%= @zone.handle.identifier %></p>
<% if @zone.description.present? %>
  <p><%= @zone.description %></p>
<% end %>
<p><strong>Config URL:</strong> <%= link_to @zone.config_url, @zone.config_url %></p>

<%= link_to "All zones", build_zones_path %>
