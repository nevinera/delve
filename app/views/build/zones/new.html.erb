<h1>Register a Zone</h1>

<%= form_with model: @zone, url: build_zones_path do |f| %>
  <% if @zone.errors.any? %>
    <ul>
      <% @zone.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :handle_id, "Handle" %>
    <%= f.select :handle_id, @handles.map { |h| [h.identifier, h.id] }, {prompt: "Select a handle"} %>
  </div>

  <div>
    <%= f.label :identifier %>
    <%= f.text_field :identifier %>
  </div>

  <div>
    <%= f.label :version %>
    <%= f.text_field :version, placeholder: "1.0" %>
  </div>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :config_url, "Config URL" %>
    <%= f.text_field :config_url %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <%= f.submit "Register" %>
<% end %>

<%= link_to "Cancel", build_zones_path %>
